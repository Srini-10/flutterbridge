{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": [
      "node"
    ],
    "noEmit": true,
    "allowJs": true,
    "rootDir": ".",
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "lib": [
      "ES2023",
      "DOM"
    ]
  },
  "include": [
    "tests/**/*.ts",
    "playwright.config.ts",
    "src/**/*.mjs"
  ]
}
