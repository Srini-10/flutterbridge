{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalDependencies": ["tsconfig.base.json", "pnpm-lock.yaml"],
  "tasks": {
    "codegen": {
      "cache": true,
      "outputs": ["src/generated/**"]
    },
    "build": {
      "dependsOn": ["codegen", "^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "corpus": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "api-check": {
      "dependsOn": ["build"],
      "outputs": ["etc/**"]
    }
  }
}
