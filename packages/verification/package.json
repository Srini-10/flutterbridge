{
  "name": "@bridge/verification",
  "version": "0.1.0",
  "description": "Verifier host, first-party verifiers (static + visual at MVP), reference-build manager, report renderer.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json && tsup",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -b tsconfig.json && tsc -p tsconfig.test.json",
    "api-check": "api-extractor run --local"
  },
  "dependencies": {
    "@bridge/uir": "workspace:*",
    "@bridge/plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "catalog:",
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flutterbridge/flutterbridge.git",
    "directory": "packages/verification"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "private": true
}
