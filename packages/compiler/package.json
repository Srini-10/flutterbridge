{
  "name": "@bridge/compiler",
  "version": "0.0.0",
  "private": true,
  "description": "Loader/linker, pass manager, normalization + analysis passes, legalization, orchestrator, manifest.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json && tsup",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -b tsconfig.json && tsc -p tsconfig.test.json",
    "api-check": "api-extractor run --local"
  },
  "dependencies": {
    "@bridge/core": "workspace:*",
    "@bridge/plugin-sdk": "workspace:*",
    "@bridge/uir": "workspace:*",
    "@material/material-color-utilities": "^0.4.0"
  },
  "devDependencies": {
    "@bridge/widgets-material": "workspace:*",
    "@microsoft/api-extractor": "catalog:",
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
