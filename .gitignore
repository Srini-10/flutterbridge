# ── Dependencies ──
node_modules/
.pnpm-store/

# ── Build outputs ──
dist/
.next/
build/
*.tsbuildinfo
.tsbuild/

# NOTE: no bare `out/` rule. The M0 spike artifacts under spikes/**/out/ are the evidence behind
# committed reports, not build output, and ignoring them would silently delete that record.

# ── Caches ──
.turbo/
.cache/
.eslintcache
.parcel-cache/
.vitest/

# ── Coverage ──
coverage/
*.lcov

# ── Logs ──
*.log
npm-debug.log*
pnpm-debug.log*
yarn-error.log*
lerna-debug.log*

# ── Environment / secrets (never commit) ──
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.keystore
.netrc

# ── Compiler working state (Spec §7.2) ──
.bridge/

# ── M0-T5 golden harness: repeatability scratch copies (baselines themselves ARE committed) ──
spikes/m0-golden/baselines/.pass1/

# ── Temporary file used by tools/verify-depcruise-negative.mjs ──
packages/uir/src/__depcruise_violation__.ts

# ── Dart / Flutter ──
.dart_tool/
.packages
.flutter-plugins
.flutter-plugins-dependencies
*.freezed.dart.bak

# ── IDE / editor ──
.idea/
.vscode/
!.vscode/extensions.json
*.iml
*.swp
*.swo
*~

# ── OS ──
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# NOTE: generated *source* is intentionally committed and must never be ignored:
#   packages/uir/src/generated/                                  (UIR model, TypeScript)
#   dart/bridge_uir/lib/generated/                               (UIR model, Dart)
#   packages/adapters/widgets-material/src/generated/            (widget catalog, TypeScript)
#   dart/bridge_analyzer/lib/src/session/adapters/widget/generated/  (widget catalog, Dart)
# These are produced by tools/schema-codegen and tools/catalog-codegen, and `just codegen-check`
# fails CI if they drift from their source of truth. They are build *inputs* for every consumer.

# M5-B: an example's build output. `bridge clean` removes both; they are regenerated by `bridge build`.
examples/*/build/
examples/*/.bridge/

# M5-C: the Dart analyzer copied into @bridge/cli by `prepack` so that publishing the CLI publishes
# the compiler frontend with it (tools/bundle-analyzer.mjs). A build artifact, not generated source:
# the source of truth is dart/, this is a copy of it, and `just package` rebuilds it from scratch.
packages/cli/vendor/

# Release artifacts — the packed tarballs `just package` produces.
#
# **Anchored.** A bare `release/` matches a directory of that name at *any* depth, and it silently
# swallowed `docs/release/` — the release report, the GitHub description and the migration notes were
# written, reported as committed, and never actually tracked. `git status` does not show ignored files, so
# a clean status looked like proof they had landed.
/release/

# M5-D: the browser suite's generated applications and Playwright output. Rebuilt by `just e2e` from the
# real pipeline on every run — a stale copy would let the suite pass against code the generator no longer
# emits, which is the specific way a browser suite becomes decorative.
e2e/.fixtures/
e2e/test-results/
e2e/playwright-report/
e2e/results.json
